{
    "name": "frontend",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "export FREEZETAG_BACKEND_ADDRESS=\"127.0.0.1\" && next dev --turbopack",
        "build": "next build --turbopack",
        "start": "next start",
        "lint": "eslint",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "test": "jest",
        "test:watch": "jest --watch",
        "deploy": "docker build -t freezetag:frontend . && docker run -d --name freezetag_frontend -p 127.0.0.1:3000:3000 freezetag:frontend",
        "kill": "docker kill freezetag_frontend && docker rm freezetag_frontend"
    },
    "dependencies": {
        "lucide-react": "^0.563.0",
        "next": "16.1.6",
        "react": "19.2.4",
        "react-dom": "19.2.4",
        "react-dropzone": "^14.4.1",
        "undici": "^7.21.0"
    },
    "devDependencies": {
        "@eslint/eslintrc": "^3.3.3",
        "@gitlab-formatters/eslint-formatter-gitlab": "^1.0.1",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@types/jest": "^30.0.0",
        "@types/node": "^24.10.13",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "baseline-browser-mapping": "^2.9.19",
        "eslint": "^9.39.2",
        "eslint-config-next": "15.5.6",
        "jest": "^30.2.0",
        "jest-environment-jsdom": "^30.2.0",
        "prettier": "^3.8.1",
        "ts-node": "^10.9.2",
        "typescript": "^5.9.3"
    },
    "prettier": {
        "tabWidth": 4
    }
}
