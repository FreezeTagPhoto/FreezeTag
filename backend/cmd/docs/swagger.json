{
    "swagger": "2.0",
    "info": {
        "description": "This is the API access for the backend of the FreezeTag app.",
        "title": "FreezeTag API",
        "contact": {},
        "version": "0.1"
    },
    "basePath": "/",
    "paths": {
        "/file/{id}": {
            "get": {
                "description": "Get an image file given an ID",
                "summary": "Get file",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "Image ID",
                        "name": "id",
                        "in": "path"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "file"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/api.StatusBadRequestResponse"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/api.StatusServerErrorResponse"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "api.StatusBadRequestResponse": {
            "type": "object",
            "properties": {
                "error": {
                    "type": "string"
                }
            }
        },
        "api.StatusServerErrorResponse": {
            "type": "object",
            "properties": {
                "error": {
                    "type": "string"
                }
            }
        }
    }
}